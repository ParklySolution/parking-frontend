          </div>

          <div className="header-right">⏱ USCITA: --:--:--</div>
        </header>

        {/* BARRA RICONOSCIMENTO CLIENTE */}
        <ClientRecognitionBar result={lookup} />

        {/* GRID */}
        <main className="ingresso-grid">
          {/* =====================
              BOX SINISTRO
          ====================== */}
          <section className="grid-box">
            <h3>🚗 Dati veicolo</h3>

            <div className="form-field">
              <label>📍 Targa</label>
              <input
                value={plateUpper}
                disabled={isPlateLocked}
                onChange={(e) => setPlate(e.target.value)}
                placeholder="Es. AB123CD"
              />
            </div>

            <div className="form-field">
              <label>🚗 Modello</label>
              <input placeholder="Seleziona modello" />
            </div>

            <div className="form-field">
              <label>🏭 Marca</label>
              <input disabled placeholder="—" />
            </div>

            <div className="form-field">
              <label>🎨 Colore</label>
              <input placeholder="Seleziona colore" />
            </div>

            <div className="form-field">
              <label>📊 Categoria</label>
              <input disabled placeholder="—" />
            </div>

            <div className="form-field">
              <label>💰 Tariffa</label>
              <input disabled placeholder="€ / h" />
            </div>
          </section>

          {/* =====================
              BOX CENTRALE
          ====================== */}
          <section className="grid-box">
            <h3>📸 Foto + Servizi</h3>

            <div className="photo-placeholder">
              📷 Foto veicolo
            </div>

            <h4 style={{ margin: "0 0 8px", opacity: 0.9 }}>
