import { useMemo, useState } from "react";
import "@/styles/exit.css";

import {
  fetchOpenSessionByTicket,
  closeParkingSession,
} from "@/services/parkingSessionService";

import { calculateParkingAmount } from "@/services/pricingEngine";
import { createPayment } from "@/services/paymentsService";
import type { PaymentMethod } from "@/services/paymentsService";

type ExitStatus = "idle" | "loading" | "ready" | "paid" | "error";

const TENANT_ID = "5f018af5-8e61-4c5c-a4f8-aa08edcadcb5";

export default function Exit() {
  const [ticket, setTicket] = useState("");
  const [status, setStatus] = useState<ExitStatus>("idle");

  const [session, setSession] = useState<any>(null);
  const [amount, setAmount] = useState<number | null>(null);

  // 💳 metodo pagamento
  const [method, setMethod] = useState<PaymentMethod>("cash");

  const ticketNumber = useMemo(
    () => Number(ticket),
    [ticket]
  );

  /* ======================================================
     🔍 CERCA SESSIONE APERTA PER TICKET
     ====================================================== */
  const handleLookup = async () => {
    if (!Number.isInteger(ticketNumber)) return;

    setStatus("loading");

    try {
      const openSession = await fetchOpenSessionByTicket(
        TENANT_ID,
        ticketNumber
      );

      if (!openSession) {
        setStatus("error");
        return;
      }

      setSession(openSession);

      // 💰 CALCOLO IMPORTO REALE
      const calculated = await calculateParkingAmount({
        tenantId: TENANT_ID,
        session: openSession,
        exitTime: new Date(),
      });

      setAmount(calculated.finalAmount);
      setStatus("ready");
    } catch (e) {
      console.error(e);
      setStatus("error");
    }
  };

  /* ======================================================
     💳 PAGAMENTO + CHIUSURA SESSIONE
     ====================================================== */
  const handlePayment = async () => {
    if (!session || amount === null) return;

    try {
      // 1️⃣ REGISTRA PAGAMENTO
      await createPayment({
        tenantId: TENANT_ID,
        sessionId: session.id,
        amount,
        method,
      });

      // 2️⃣ CHIUDI SESSIONE
      await closeParkingSession({
        sessionId: session.id,
        finalAmount: amount,
      });

      setStatus("paid");
    } catch (e) {
      console.error(e);
      setStatus("error");
    }
  };

  return (
    <div className="exit-container">
      <div className="exit-box">
        <h2>🚗 USCITA VEICOLO</h2>

        {/* INPUT TICKET */}
        <div className="form-field">
          <label>🎫 Numero ticket</label>
          <input
            value={ticket}
            onChange={(e) => setTicket(e.target.value)}
            placeholder="Inserisci numero ticket (0–199)"
            inputMode="numeric"
          />
        </div>

        <button className="btn primary" onClick={handleLookup}>
          🔍 Calcola importo
        </button>

        {/* RISULTATO */}
        {status === "ready" && (
          <div className="exit-summary">
            <p>
              ⏱️ Ingresso:{" "}
              {new Date(session.entry_time).toLocaleString("it-IT")}
            </p>
            <p>
              ⏱️ Uscita: {new Date().toLocaleString("it-IT")}
            </p>
            <p>
              💰 Importo da pagare:{" "}
              <strong>€ {amount?.toFixed(2)}</strong>
            </p>

            {/* 💳 METODO PAGAMENTO */}
            <div className="payment-methods">
              <label>
                <input
                  type="radio"
                  checked={method === "cash"}
                  onChange={() => setMethod("cash")}
                />
                💵 Contanti
              </label>

              <label>
                <input
                  type="radio"
                  checked={method === "pos"}
                  onChange={() => setMethod("pos")}
                />
                💳 POS
              </label>
            </div>

            <button className="btn success" onClick={handlePayment}>
              💳 Conferma pagamento
            </button>
          </div>
        )}

        {status === "paid" && (
          <div className="exit-success">
            ✅ Pagamento registrato
            <br />
            🚦 Barriera aperta
          </div>
        )}

        {status === "error" && (
          <div className="exit-error">
            ❌ Ticket non valido o sessione non trovata
          </div>
        )}
      </div>
    </div>
  );
}

