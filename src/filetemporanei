            </h4>
            <div className="services-row">
              <button>Esterno</button>
              <button>Completo</button>
              <button>Interni</button>
            </div>
          </section>

          {/* =====================
              BOX DESTRO
          ====================== */}
          <section className="grid-box">
            <h3>⚙️ Azioni</h3>

