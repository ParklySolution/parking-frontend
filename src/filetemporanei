import { useEffect, useMemo, useState } from "react";
import { useLocation, useNavigate } from "react-router-dom";

import "@/styles/ingresso.css";

import ClientRecognitionBar from "@/components/ingress/ClientRecognitionBar";
import { lookupCustomerByPlate } from "@/services/customerLookupService";
import type { CustomerLookupResult } from "@/services/customerLookupService";
import { useDebouncedValue } from "@/hooks/useDebouncedValue";

import { fetchVehicleProfileByPlate } from "@/services/vehicleProfileService";
import type { VehicleProfileByPlate } from "@/types/vehicleProfile";

import {
  searchVehicleModels,
  type VehicleModelSearchResult,
} from "@/services/vehicleModelSearchService";

import { createParkingSession } from "@/services/parkingSessionService";

function nowLabel() {
  const d = new Date();
  return {
    time: d.toLocaleTimeString("it-IT"),
    date: d.toLocaleDateString("it-IT"),
  };
}

const TENANT_ID = "5f018af5-8e61-4c5c-a4f8-aa08edcadcb5";

export default function Ingresso() {
  const location = useLocation();
  const navigate = useNavigate();

  /* ===============================
     TARGA DALLA DASHBOARD
     =============================== */
  const initialPlate = location.state?.plate ?? "";
  const [plate] = useState(() => initialPlate);
  const plateDebounced = useDebouncedValue(plate, 400);

  const plateUpper = useMemo(
    () => plate.replace(/\s+/g, "").toUpperCase(),
    [plate]
  );

  /* ===============================
     STATO CLIENTE
     =============================== */
  const [lookup, setLookup] = useState<CustomerLookupResult>({
    status: "idle",
  });

  /* ===============================
     PROFILO VEICOLO (SE ESISTE)
     =============================== */
  const [vehicleProfile, setVehicleProfile] =
    useState<VehicleProfileByPlate | null>(null);

  /* ===============================
     AUTOCOMPLETE MODELLI
     =============================== */
  const [modelInput, setModelInput] = useState("");
  const [modelResults, setModelResults] = useState<
    VehicleModelSearchResult[]
  >([]);
  const [selectedModel, setSelectedModel] =
    useState<VehicleModelSearchResult | null>(null);

  /* ===============================
     CLOCK HEADER
     =============================== */
  const [clock, setClock] = useState(() => nowLabel());
  useEffect(() => {
    const t = setInterval(() => setClock(nowLabel()), 1000);
    return () => clearInterval(t);
  }, []);

  /* ===============================
     LOOKUP CLIENTE / ABBONAMENTO
     =============================== */
  useEffect(() => {
    let active = true;

    const run = async () => {
      if (plateDebounced.length < 5) {
        setLookup({ status: "idle" });
        return;
      }

      setLookup({ status: "loading" });
      const res = await lookupCustomerByPlate(plateUpper);
      if (!active) return;
      setLookup(res);
    };

    run();
    return () => {
      active = false;
    };
  }, [plateDebounced, plateUpper]);

  /* ===============================
     LOOKUP PROFILO VEICOLO
     =============================== */
  useEffect(() => {
    let active = true;

    const run = async () => {
      if (plateUpper.length < 5) {
        setVehicleProfile(null);
        return;
      }

      const profile = await fetchVehicleProfileByPlate(
        plateUpper,
        TENANT_ID
      );

      if (!active) return;

      setVehicleProfile(profile);
      if (profile) {
        setSelectedModel(null);
        setModelInput("");
        setModelResults([]);
      }
    };

    run();
    return () => {
      active = false;
    };
  }, [plateUpper]);

  /* ===============================
     AUTOCOMPLETE MODELLI (NUOVO VEICOLO)
     =============================== */
  useEffect(() => {
    if (vehicleProfile) return;
    if (modelInput.length < 2) {
      setModelResults([]);
      return;
    }

    const run = async () => {
      const res = await searchVehicleModels(
        modelInput,
        TENANT_ID,
        10
      );
      setModelResults(res);
    };

    run();
  }, [modelInput, vehicleProfile]);

  /* ===============================
     CREA SESSIONE + STAMPA TICKET
     =============================== */
  const handlePrintTicket = async () => {
    const categoryId =
      vehicleProfile?.category?.id ?? selectedModel?.category_id;

    if (!categoryId) {
      alert("Categoria veicolo mancante");
      return;
    }

    try {
      await createParkingSession({
        tenantId: TENANT_ID,
        categoryId,
        vehicleProfileId: vehicleProfile?.id ?? null,
        modelId: selectedModel?.model_id ?? null,
        subscriptionId: lookup.subscription?.id ?? null,
        conventionId: lookup.convention?.id ?? null,
        ticketNumber: null, // Il sistema genera automaticamente il numero ticket
      });

      navigate("/");
    } catch (err) {
      console.error(err);
      alert("Errore durante la creazione del ticket");
    }
  };

  /* ===============================
     RENDER
     =============================== */
  return (
    <div className="ingresso-container">
      <div className="ingresso">
        <header className="ingresso-header">
          <div className="header-left">
            🕐 ENTRATA: <strong>{clock.time}</strong> {clock.date}
          </div>
          <div className="header-center">
            🎯 REGISTRAZIONE INGRESSO – NUOVA SOSTA
          </div>
          <div className="header-right">⏱ USCITA: --:--:--</div>
        </header>

        <ClientRecognitionBar result={lookup} />

        <main className="ingresso-grid">
          {/* ================= DATI VEICOLO ================= */}
          <section className="grid-box">
            <h3>🚗 Dati veicolo</h3>

            <div className="form-field">
              <label>📍 Targa</label>
              <input value={plateUpper} readOnly className="readonly" />
            </div>

            <div className="form-field">
              <label>🚗 Modello</label>
              <input
                value={
                  vehicleProfile
                    ? vehicleProfile.model?.name ?? ""
                    : selectedModel?.model_name ?? modelInput
                }
                onChange={(e) => setModelInput(e.target.value)}
                disabled={!!vehicleProfile}
                placeholder="Inizia a digitare il modello"
              />

              {!vehicleProfile && modelResults.length > 0 && (
                <div className="autocomplete">
                  {modelResults.map((m) => (
                    <div
                      key={m.model_id}
                      className="autocomplete-item"
                      onClick={() => {
                        setSelectedModel(m);
                        setModelInput(m.model_name);
                        setModelResults([]);
                      }}
                    >
                      {m.model_name} — {m.brand_name}
                    </div>
                  ))}
                </div>
              )}
            </div>

            <div className="form-field">
              <label>🏭 Marca</label>
              <input
                value={
                  vehicleProfile
                    ? vehicleProfile.brand?.name ?? ""
                    : selectedModel?.brand_name ?? ""
                }
                disabled
              />
            </div>

            <div className="form-field">
              <label>📊 Categoria</label>
              <input
                value={
                  vehicleProfile
                    ? vehicleProfile.category?.name ?? ""
                    : selectedModel?.category_name ?? ""
                }
                disabled
              />
            </div>

            <div className="form-field">
              <label>💰 Tariffa</label>
              <input value="Calcolo in uscita" disabled />
            </div>
          </section>

          {/* ================= FOTO ================= */}
          <section className="grid-box">
            <h3>📸 Foto</h3>
            <div className="photo-placeholder">📷 Foto veicolo</div>
          </section>

          {/* ================= AZIONI ================= */}
          <section className="grid-box">
            <h3>⚙️ Azioni</h3>

            <button className="btn cancel" onClick={() => navigate(-1)}>
              ❌ Annulla
            </button>

            <button
              className="btn primary"
              onClick={handlePrintTicket}
            >
