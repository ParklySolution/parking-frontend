        {/* BODY - GRIGLIA 3x2 CORRETTA */}
        <main className="dashboard-grid">
          {/* BOX 1: TARGHE LIVE (SINISTRA ALTO) */}
          <section className="grid-cell targhe-live">
            <h3>📝 Targhe rilevate</h3>
            {/* PLACEHOLDER per targhe - manteniamo PlatesStream se esiste */}
